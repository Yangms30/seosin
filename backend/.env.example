# OpenAI API (default LLM) - https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

# TTS — ElevenLabs (primary, recommended for best voice quality)
# Get key: https://elevenlabs.io/app/settings/api-keys
# Get voice_id: https://elevenlabs.io/app/voice-library (Korean voices recommended)
# When ELEVENLABS_API_KEY is set, services/tts.py prefers ElevenLabs over OpenAI TTS.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# TTS — OpenAI fallback (gpt-4o-mini-tts). Used only if ELEVENLABS_API_KEY is empty.
# (Falls back automatically; no extra flag needed.)

# Gemini API (legacy LLM fallback, optional) - https://ai.google.dev
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Database
DATABASE_URL=sqlite:///./briefbot.db

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# LLM
LLM_MAX_RETRIES=2

# Pipeline
COLLECT_PER_CATEGORY=20
CLUSTER_THRESHOLD=0.6
ARTICLE_HOURS=24

# Email (optional, Gmail SMTP) - leave blank to disable
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
